# Expo inlines vars prefixed with EXPO_PUBLIC_ into process.env at build time.
# Restart `expo start` after editing this file — Metro caches env values.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# URL of your deployed Cloud Functions (e.g. https://us-central1-<project>.cloudfunctions.net).
# Leave EMPTY during local dev to use the Expo Router API route at
# app/api/generate+api.ts instead — that route reads GEMINI_API_KEY below.
EXPO_PUBLIC_CLOUD_FUNCTIONS_URL=

# Server-only key, used by app/api/generate+api.ts during local dev.
# NO EXPO_PUBLIC_ prefix — we do NOT want this inlined into the client bundle.
# The Expo dev server exposes it to API routes via process.env at request time.
GEMINI_API_KEY=

# Optional: override the image edit/generation model.
# Defaults to gemini-2.5-flash-image. Other options that your key may have:
#   gemini-3.1-flash-image-preview
#   gemini-3-pro-image-preview
# List what your key can use:
#   curl "https://generativelanguage.googleapis.com/v1beta/models?key=$GEMINI_API_KEY"
GEMINI_IMAGE_MODEL=

EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=
