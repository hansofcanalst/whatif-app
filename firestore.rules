rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && !('subscriptionStatus' in request.resource.data.diff(resource.data).affectedKeys())
        && !('freeGenerationsUsed' in request.resource.data.diff(resource.data).affectedKeys());
      // Owners can delete their own account (the Profile screen's
      // "Delete Account" flow). Required for App Store policy and
      // GDPR/CCPA right-to-erasure compliance.
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
    match /generations/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Owners can delete their own entries (the Gallery's long-press flow).
      // Create + update remain server-only — the Cloud Function writes
      // generations via Admin SDK which bypasses these rules.
      // Note: deleting the Firestore doc leaves the Storage objects
      // (original + result images) orphaned. A periodic Cloud Function
      // sweep is the right cleanup mechanism; not blocking on it for
      // MVP because the storage cost is negligible at current scale.
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update: if false;
    }
    match /subscriptions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    match /rateLimits/{uid} {
      allow read, write: if false;
    }
    // Per-variant telemetry. Written exclusively server-side by the
    // generate Cloud Function (Admin SDK bypasses these rules). No
    // client access — inspect via the Firebase console or a server-side
    // admin-tool query. Schema:
    //   generationId, userId, categoryId, subcategoryId,
    //   status ('complete' | 'failed'), errorMessage?, durationMs,
    //   promptSource, attempts, modelId, source, timestamp
    match /logs/{id} {
      allow read, write: if false;
    }
    // Moderation audit log. Written server-side by the generate Cloud
    // Function (Admin SDK bypasses rules). No client read or write —
    // this is an audit trail for takedown / abuse review and must not
    // be tamperable from the client. The local-dev client write in
    // lib/gemini.ts (persistLocalGeneration) silently fails here on
    // purpose; production audit goes through the Cloud Function path.
    match /moderation_log/{id} {
      allow read, write: if false;
    }
  }
}
